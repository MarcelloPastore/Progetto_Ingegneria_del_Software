### CASA - 0. HEALTH CHECK
GET http://localhost:2310/api/v1/health

### CASA - 1. REGISTER Alice (se non esistente)
POST http://localhost:2310/api/v1/auth/register
Content-Type: application/json

{
  "email": "alice@example.com",
  "password": "SecurePass123!",
  "username": "alice123",
  "nome": "Alice",
  "cognome": "Rossi"
}

### CASA - 2. REGISTER Bob (se non esistente)
POST http://localhost:2310/api/v1/auth/register
Content-Type: application/json

{
  "email": "bob@example.com",
  "password": "SecurePass456!",
  "username": "bob456",
  "nome": "Bob",
  "cognome": "Verdi"
}

### CASA - 3. LOGIN Alice (salva token e user_id)
POST http://localhost:2310/api/v1/auth/login
Content-Type: application/json

{
  "email": "alice@example.com",
  "password": "SecurePass123!"
}

> {%
    client.global.set("auth_token", response.body.token);
    client.global.set("user_id_alice", response.body.user.id);
    console.log("✓ auth_token (Alice) salvato:", response.body.token?.substring(0, 20) + "...");
%}

### CASA - 4. LOGIN Bob (salva token)
POST http://localhost:2310/api/v1/auth/login
Content-Type: application/json

{
  "email": "bob@example.com",
  "password": "SecurePass456!"
}

> {%
    client.global.set("auth_token_bob", response.body.token);
    client.global.set("user_id_bob", response.body.user?.id);
    console.log("✓ auth_token_bob salvato:", response.body.token?.substring(0, 20) + "...");
%}

### CASA - 5. CREA CASA (Alice) → salva casa_id e inviteLink
POST http://localhost:2310/api/v1/case
Content-Type: application/json
Authorization: Bearer {{ auth_token }}

{
  "nome": "Casa Test",
  "indirizzo": "Via dei Test 1",
  "citta": "TestTown",
  "tipoCasa": "Appartamento"
}

> {%
    client.global.set("casa_id", response.body.id);
    client.global.set("invite_link", response.body.inviteLink);
    console.log("✓ casa_id:", response.body.id);
    console.log("✓ invite_link:", response.body.inviteLink);
%}

### CASA - 6. LISTA CASE (Alice) - verifica che la casa appaia
GET http://localhost:2310/api/v1/case
Authorization: Bearer {{ auth_token }}

### CASA - 7. DETTAGLIO CASA (Alice)
GET http://localhost:2310/api/v1/case/{{ casa_id }}
Authorization: Bearer {{ auth_token }}

### CASA - 8. GET INVITE LINK (Alice) - senza rigenerare
GET http://localhost:2310/api/v1/case/{{ casa_id }}/invite-link
Authorization: Bearer {{ auth_token }}

> {%
    client.global.set("invite_link_check", response.body.inviteLink);
    console.log("✓ invite_link_check:", response.body.inviteLink);
%}

### CASA - 9. RIGENERA INVITE LINK (Alice) - rigenera=true
GET http://localhost:2310/api/v1/case/{{ casa_id }}/invite-link?rigenera=true
Authorization: Bearer {{ auth_token }}

> {%
    client.global.set("invite_link_regenerated", response.body.inviteLink);
    console.log("✓ invite_link_regenerated:", response.body.inviteLink);
%}

### CASA - 11. BOB SI AGGIUNGE ALLA CASA USANDO invite_link_regenerated
POST http://localhost:2310/api/v1/case/{{ casa_id }}/inquilini
Content-Type: application/json
Authorization: Bearer {{ auth_token_bob }}

{
  "inviteLink": "{{ invite_link_regenerated }}"
}

> {%
    client.global.set("membro_casa_id_bob", response.body.id);
    client.global.set("inquilino_id_bob", response.body.utente.id);
    console.log("✓ Bob membro_casa_id:", response.body.id);
    console.log("✓ Bob inquilino_id (idUtente):", response.body.utente.id);
%}

### CASA - 12. LISTA INQUILINI (Alice)
GET http://localhost:2310/api/v1/case/{{ casa_id }}/inquilini
Authorization: Bearer {{ auth_token }}

### CASA - 13. DETTAGLIO INQUILINO (Alice) - il Bob appena aggiunto
GET http://localhost:2310/api/v1/case/{{ casa_id }}/inquilini/{{ inquilino_id_bob }}
Authorization: Bearer {{ auth_token }}

### CASA - 14. PROMUOVI INQUILINO A HomeAdmin (Alice)
PUT http://localhost:2310/api/v1/case/{{ casa_id }}/inquilini/{{ inquilino_id_bob }}/ruolo
Content-Type: application/json
Authorization: Bearer {{ auth_token }}

{
  "ruolo": "HomeAdmin"
}

> {%
    client.global.set("membro_casa_id_bob", response.body.id);
    console.log("✓ Inquilino promosso:", response.body.id, response.body.ruolo);
%}

### CASA - 15. VERIFICA RUOLO DOPO PROMOZIONE
GET http://localhost:2310/api/v1/case/{{ casa_id }}/inquilini/{{ inquilino_id_bob }}
Authorization: Bearer {{ auth_token }}

### CASA - 16. DEGRADA INQUILINO A Inquilino (Alice)
PUT http://localhost:2310/api/v1/case/{{ casa_id }}/inquilini/{{ inquilino_id_bob }}/ruolo
Content-Type: application/json
Authorization: Bearer {{ auth_token }}

{
  "ruolo": "Inquilino"
}

> {%
    console.log("✓ Degradato:", response.body.id, response.body.ruolo);
%}

### CASA - 17. RIMUOVI INQUILINO (Alice) - delete Bob
DELETE http://localhost:2310/api/v1/case/{{ casa_id }}/inquilini/{{ inquilino_id_bob }}
Authorization: Bearer {{ auth_token }}

### CASA - 18. LISTA INQUILINI DOPO RIMOZIONE (Alice) - verifica che Bob non ci sia più
GET http://localhost:2310/api/v1/case/{{ casa_id }}/inquilini
Authorization: Bearer {{ auth_token }}

### CASA - 19. BOB SI RIAFFERISCE CON L'ULTIMO INVITE LINK (ri-aggiungi)
POST http://localhost:2310/api/v1/case/{{ casa_id }}/inquilini
Content-Type: application/json
Authorization: Bearer {{ auth_token_bob }}

{
  "inviteLink": "{{ invite_link_regenerated }}"
}

> {%
    client.global.set("membro_casa_id_bob_readded", response.body.id);
    client.global.set("inquilino_id_bob_readded", response.body.utente.id);
    console.log("✓ Bob readded member id:", response.body.id);
    console.log("✓ Bob readded user id:", response.body.utente.id);
%}

### CASA - 20. ELIMINA CASA (Alice) - Solo HomeAdmin può farlo
DELETE http://localhost:2310/api/v1/case/{{ casa_id }}
Authorization: Bearer {{ auth_token }}

### CASA - 21. (OPZIONALE) PROVA A LEGGERE LA CASA DOPO LA CANCELLAZIONE (dovrebbe essere 404)
GET http://localhost:2310/api/v1/case/{{ casa_id }}
Authorization: Bearer {{ auth_token }}