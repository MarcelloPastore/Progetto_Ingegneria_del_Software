generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model User {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  email    String  @unique
  password String
  nome     String
  cognome  String
  ruolo    Ruolo   @default(Inquilino)
  casa     Casa?   @relation(fields: [casaId], references: [id])
  casaId   String? @db.ObjectId

  @@map("Utenti")
}

model Casa {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  nome      String
  indirizzo String
  utenti    User[]

  @@map("Case")
}

enum Ruolo {
  SysAdmin
  HomeAdmin
  Inquilino
}
